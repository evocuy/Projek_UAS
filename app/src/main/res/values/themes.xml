<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Projek_UAS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_gold</item>
        <item name="colorPrimaryVariant">@color/primary_gold_dark</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_neon_blue</item>
        <item name="colorSecondaryVariant">@color/accent_neon_blue</item>
        <item name="colorOnSecondary">@color/bg_dark</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <style name="Theme.Projek_UAS" parent="Base.Theme.Projek_UAS" />
</resources>